FROM node:20-alpine

WORKDIR /app

ARG VITE_COLLAB_WS_URL
ARG VITE_COLLAB_URL
ARG VITE_MATCHING_API_URL
ARG VITE_MATCHING_WS_URL
ENV VITE_COLLAB_WS_URL=$VITE_COLLAB_WS_URL
ENV VITE_COLLAB_URL=$VITE_COLLAB_URL
ENV VITE_MATCHING_API_URL=$VITE_MATCHING_API_URL
ENV VITE_MATCHING_WS_URL=$VITE_MATCHING_WS_URL

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

EXPOSE 5173

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "5173"]
